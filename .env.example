# Anti - Variables de Entorno (Ejemplo)
# ==================================
# Copiar este archivo a .env y completar con tus keys
# 
# cp .env.example .env
#
# ⚠️ .env está en .gitignore - NO se sube a GitHub

# --- OpenAI (opcional) ---
# Obtenela en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-tu-key-aqui

# --- Google Gemini (opcional) ---
# Obtenela en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu-key-aqui

# --- LM Studio (default) ---
# No requiere key - solo corre LM Studio en http://127.0.0.1:1234
# LM_STUDIO_URL=http://127.0.0.1:1234/v1

# --- Ollama (default) ---
# No requiere key - solo corre Ollama en http://127.0.0.1:11434
# OLLAMA_URL=http://127.0.0.1:11434